---

---
<section id="education" class="py-12 border-t border-[#ffffff10] text-[var(--white)]">
    <div class="max-w-5xl mx-auto">
        <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">My background</h2>
        <h3 class="text-4xl md:text-5xl font-medium mb-8">Education</h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Master -->
            <div class="rounded-2xl border border-[var(--white-icon-tr)] bg-[#1414149c] p-6 md:p-8 hover:border-[#ffffff25] transition duration-300">
                <div class="flex items-center justify-between mb-4">
                    <span class="text-xs tracking-widest uppercase text-[var(--sec)]">Master</span>
                    <span class="text-xs text-[var(--white-icon)] tabular-nums">2026 – Present</span>
                </div>
                <h4 class="text-xl font-semibold mb-1">Department of Computer Science and Information Engineering</h4>
                <p class="text-sm text-[var(--white-icon)]">National Taiwan University</p>
            </div>

            <!-- Bachelor -->
            <div class="rounded-2xl border border-[var(--white-icon-tr)] bg-[#1414149c] p-6 md:p-8 hover:border-[#ffffff25] transition duration-300">
                <div class="flex items-center justify-between mb-4">
                    <span class="text-xs tracking-widest uppercase text-[var(--sec)]">Bachelor</span>
                    <span class="text-xs text-[var(--white-icon)] tabular-nums">2024 – 2026</span>
                </div>
                <h4 class="text-xl font-semibold mb-1">Department of Computer Science and Engineering</h4>
                <p class="text-sm text-[var(--white-icon)]">National Chung Hsing University</p>
            </div>

        </div>
    </div>
</section>